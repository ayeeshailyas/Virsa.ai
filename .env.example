# Gemini API Key: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For local development, create a .env file and paste your key here:
# GEMINI_API_KEY=your_actual_key_here
GEMINI_API_KEY=

# Note: Do NOT commit your actual .env file to version control.
# .gitignore is already configured to ignore .env files.
